{
    "manifest_version": 3,
    "name": "Simpliciyt",
    "version": "1.0",
    "description": "I love simplicity on youtube",
    "permissions": [
        "scripting"
    ],
    "host_permissions": [
        "*://www.youtube.com/*"
    ],
    "icons": {
        "48": "icons/icon-48.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "simplicity@appez.cafe"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/feed/subscriptions*"
            ],
            "js": [
                "simpliciyt.js"
            ]
        }
    ]
}
